# ─── Shared ─────────────────────────────────────────────
# Secret used to sign/verify access-token JWTs. Auth signs, Gateway verifies.
JWT_SECRET=super-secret-change-me
# Short-lived access token; long-lived (revocable) refresh token.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
# Refresh token is delivered as an httpOnly cookie. Set COOKIE_SECURE=true in
# production (HTTPS); keep false for local http://localhost.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ─── Postgres (Auth service) ────────────────────────────
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpass
POSTGRES_DB=authdb
# Connection string used by Prisma inside the auth-service container.
DATABASE_URL=postgresql://taskuser:taskpass@postgres:5432/authdb?schema=public

# ─── Postgres (Project service) ─────────────────────────
PROJECT_POSTGRES_USER=projectuser
PROJECT_POSTGRES_PASSWORD=projectpass
PROJECT_POSTGRES_DB=projectdb
# Connection string used by Prisma inside the project-service container.
PROJECT_DATABASE_URL=postgresql://projectuser:projectpass@project-postgres:5432/projectdb?schema=public

# ─── MongoDB (Task service) ─────────────────────────────
MONGO_URL=mongodb://mongo:27017/taskdb

# ─── RabbitMQ (Task + Notification) ─────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=task_events

# ─── Service ports ──────────────────────────────────────
GATEWAY_PORT=8080
AUTH_PORT=4001
TASK_PORT=4002
NOTIFICATION_PORT=4003
PROJECT_PORT=4004

# ─── Internal service URLs (service-to-service) ─────────
AUTH_SERVICE_URL=http://auth-service:4001
TASK_SERVICE_URL=http://task-service:4002
PROJECT_SERVICE_URL=http://project-service:4004
